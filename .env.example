# Hikmalayer Testnet Environment — TEMPLATE
# Copy this file to .env and fill in real values
# NEVER commit .env — it is gitignored

# Shared authentication tokens
P2P_TOKEN=replace-with-strong-random-token
ADMIN_TOKEN=replace-with-strong-random-token

# Optional (R-05): HMAC signing keys enabling self-expiring signed tokens
# minted with `cargo run --bin mint_token -- --scope admin --ttl 86400`.
# Generate each with: openssl rand -hex 32
# ADMIN_TOKEN_SIGNING_KEY=
# P2P_TOKEN_SIGNING_KEY=

# Node keys — generate each with: ./target/release/hikma-wallet keygen
BOOTNODE_VALIDATOR_KEY=replace-with-keygen-private-key
BOOTNODE_TREASURY_KEY=replace-with-keygen-private-key
VALIDATOR1_KEY=replace-with-keygen-private-key
VALIDATOR2_KEY=replace-with-keygen-private-key
VALIDATOR3_KEY=replace-with-keygen-private-key
VALIDATOR4_KEY=replace-with-keygen-private-key

# Launch posture: comma-separated addresses allowed to register validator
# stakes, baked into the genesis state root (empty/unset = permissionless).
# Set this for a permissioned-hybrid launch; open it later via a scheduled
# network upgrade.
# GENESIS_VALIDATOR_ALLOWLIST=hkm...,hkm...

# Grafana dashboard password
GF_SECURITY_ADMIN_PASSWORD=replace-with-strong-password

# R-02: Sybil protection — comma-separated list of permitted P2P node IDs
# Get node IDs from container logs: docker compose logs <node> | grep "P2P node identity"
P2P_ALLOWLIST=hkm...,hkm...,hkm...

# Require signed P2P envelopes (true/false)
P2P_REQUIRE_IDENTITY=true
